    {
      "id": "frankow-ml",
      "name": "Frankow (ML Pipeline)",
      "root": "G:\\Applications-2026-02-02-frankow",
      "layout": {
        "type": "tabs",
        "items": [
          {
            "title": "Frankow Shell",
            "profileId": "pwsh",
            "cwd": "G:\\Applications-2026-02-02-frankow"
          }
        ]
      },
      "tasks": {
        "Frankow - up": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose up --build" }
          ]
        },
        "Frankow - down": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose down" }
          ]
        },
        "Frankow - seed": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose exec api python -m app.etl.seed --limit 1000" }
          ]
        },
        "Frankow - train baseline": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose exec api python -m app.ml.train_baseline --version v1" }
          ]
        },
        "Frankow - train main": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose exec api python -m app.ml.train_main --version v1 --model xgboost" }
          ]
        },
        "Frankow - train per league": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            {
              "run": "docker compose exec -e PYTHONUNBUFFERED=1 api python -u -m app.ml.train_per_league --trainer main --model xgboost --continue-on-error --verbose-eval 1 --no-calibrate --n-estimators 5"
            }
          ]
        },
        "Frankow - re-train per league": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            {
              "run": "docker compose exec -e PYTHONUNBUFFERED=1 api python -u -m app.ml.train_per_league --trainer main --model xgboost --no-skip-existing --best-metric val_log_loss --remember-best --n-estimators 6"
            }
          ]
        },
        "Frankow - predict db": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose exec api python -m app.ml.predict_to_db --version v1 --model main_xgboost" }
          ]
        },
        "Frankow - report": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose exec api python -m app.reporting.prediction_report" }
          ]
        },
        "Frankow - logs": {
          "cwd": "G:\\Applications-2026-02-02-frankow",
          "steps": [
            { "run": "docker compose logs -f --tail=200" }
          ]
        }
      },
      "quickTasks": [
        "Frankow - up",
        "Frankow - logs"
      ]
    },
